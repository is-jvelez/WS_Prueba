<?xml version="1.0"?>
<configuration>
  <!--
    Para obtener una descripción de los cambios de web.config, vea http://go.microsoft.com/fwlink/?LinkId=235367.

    Los siguientes atributos se pueden establecer en la etiqueta <httpRuntime>.
      <system.Web>
        <httpRuntime targetFramework="4.8" />
      </system.Web>
  -->
  <connectionStrings>
    <!--
      Apunta al SQL Server levantado por docker-compose y migrado por el servicio "flyway"
      (ver carpeta /flyway). Se publica en el puerto 15533 del host (no 1433) porque esta
      máquina ya tiene una instancia local de SQL Server escuchando en 1433 (ver sqlservr.exe)
      y otro stack Docker distinto ya ocupaba 14330; si cambias SQLSERVER_HOST_PORT en .env,
      actualiza también el puerto aquí.
      Ajusta usuario/password para que coincidan con SA_PASSWORD/DB_NAME definidos en tu .env.
    -->
    <add name="IS_WS_PRUEBAConnection"
         connectionString="Server=localhost,15533;Database=IS_WS_PRUEBA;User Id=sa;Password=MyPassword123#2026;Encrypt=True;TrustServerCertificate=True;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
  <system.web>
    <compilation debug="true" targetFramework="4.8"/>
    <webServices>
      <protocols>
        <add name="HttpSoap"/>
        <add name="HttpPost"/>
      </protocols>
    </webServices>
    <customErrors mode="Off"/>
    <pages controlRenderingCompatibilityVersion="4.0"/>
  </system.web>
</configuration>